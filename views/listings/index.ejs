<% layout('layouts/boilerplate') %>

  <div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1 class="text-gradient">
        <% if (locals.category && locals.category !=='All' ) { %>
          <i class="fas fa-filter me-2"></i>
          <%= category %> Listings
            <% } else { %>
              <i class="fas fa-map-marked-alt me-2"></i>Explore Amazing Places
              <% } %>
      </h1>
      <% if (currUser) { %>
        <a href="/listings/new" class="btn btn-primary">
          <i class="fas fa-plus-circle me-2"></i>Add New Listing
        </a>
        <% } %>
    </div>

    <% if (listings && listings.length> 0) { %>
      <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        <% listings.forEach(listing=> { %>
          <div class="col">
            <div class="card h-100 hover-lift">

              <!-- Listing Image -->
              <% if (listing.images && listing.images.length> 0) { %>
                <% const cover = (listing.coverImageFilename && listing.images.find(i => i.filename === listing.coverImageFilename)) || listing.images[0]; %>
                <img src="<%= cover.url %>" class="card-img-top" alt="<%= listing.title %>" loading="lazy">
                <% } else { %>
                  <img src="https://via.placeholder.com/400x250?text=No+Image" class="card-img-top"
                    alt="No image available">
                  <% } %>

                    <!-- Category Badge -->
                    <span class="category-badge">
                      <%= listing.category || 'Hotels' %>
                    </span>

                    <!-- Card Body -->
                    <div class="card-body d-flex flex-column">
                      <h5 class="card-title">
                        <%= listing.title %>
                      </h5>

                      <p class="text-muted mb-2">
                        <i class="fas fa-map-marker-alt text-danger me-1"></i>
                        <%= listing.location %>, <%= listing.country %>
                      </p>

                      <p class="card-text text-muted flex-grow-1">
                        <%= listing.description.substring(0, 100) %>
                          <%= listing.description.length> 100 ? '...' : '' %>
                      </p>

                      <div class="d-flex justify-content-between align-items-center mt-3">
                        <span class="price-badge">
                          <i class="fas fa-rupee-sign me-1"></i>
                          <%= listing.price.toLocaleString() %>
                            <small>/night</small>
                        </span>

                        <% if (listing.reviews && listing.reviews.length> 0) {
                          let totalRating = 0;
                          listing.reviews.forEach(r => totalRating += r.rating);
                          let avgRating = (totalRating / listing.reviews.length).toFixed(1);
                          %>
                          <span class="text-warning fw-bold">
                            <i class="fas fa-star me-1"></i>
                            <%= avgRating %>
                          </span>
                          <% } else { %>
                            <span class="text-muted small">New</span>
                            <% } %>
                      </div>

                      <a href="/listings/<%= listing._id %>" class="btn btn-sm btn-outline-primary w-100 mt-3">
                        View Details <i class="fas fa-arrow-right ms-1"></i>
                      </a>
                    </div>

            </div>
          </div>
          <% }) %>
      </div>
      <% } else { %>
        <div class="text-center py-5">
          <i class="fas fa-search fa-4x text-muted mb-3"></i>
          <h3 class="text-muted">No listings found</h3>
          <p class="text-muted">Be the first to add a listing!</p>
          <% if (currUser) { %>
            <a href="/listings/new" class="btn btn-primary mt-3">
              <i class="fas fa-plus-circle me-2"></i>Create First Listing
            </a>
            <% } %>
        </div>
        <% } %>
  </div>

  <style>
    .text-gradient {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
  </style>