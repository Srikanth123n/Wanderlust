<% layout('layouts/boilerplate') %>

    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="fas fa-building me-2"></i>My Listings</h2>
            <a href="/listings/new" class="btn btn-primary">
                <i class="fas fa-plus-circle me-2"></i>Add New Listing
            </a>
        </div>

        <% if (listings && listings.length> 0) { %>
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                <% listings.forEach(listing=> { %>
                    <div class="col">
                        <div class="card h-100 hover-lift">

                            <!-- Listing Image -->
                            <% if (listing.images && listing.images.length> 0) { %>
                                <% const cover = (listing.coverImageFilename && listing.images.find(i => i.filename === listing.coverImageFilename)) || listing.images[0]; %>
                                <img src="<%= cover.url %>" class="card-img-top" alt="<%= listing.title %>">
                                <% } else { %>
                                    <img src="https://via.placeholder.com/400x250?text=No+Image" class="card-img-top"
                                        alt="No image">
                                    <% } %>

                                        <!-- Category Badge -->
                                        <span class="category-badge">
                                            <%= listing.category || 'Hotels' %>
                                        </span>

                                        <!-- Card Body -->
                                        <div class="card-body d-flex flex-column">
                                            <h5 class="card-title">
                                                <%= listing.title %>
                                            </h5>

                                            <p class="text-muted mb-2">
                                                <i class="fas fa-map-marker-alt text-danger me-1"></i>
                                                <%= listing.location %>, <%= listing.country %>
                                            </p>

                                            <p class="card-text text-muted flex-grow-1">
                                                <%= listing.description.substring(0, 100) %>
                                                    <%= listing.description.length> 100 ? '...' : '' %>
                                            </p>

                                            <div class="d-flex justify-content-between align-items-center mt-3">
                                                <span class="price-badge">
                                                    ₹<%= listing.price.toLocaleString() %>/night
                                                </span>
                                            </div>

                                            <!-- Action Buttons -->
                                            <div class="d-flex gap-2 mt-3">
                                                <a href="/listings/<%= listing._id %>"
                                                    class="btn btn-sm btn-primary flex-fill">
                                                    <i class="fas fa-eye me-1"></i>View
                                                </a>
                                                <a href="/listings/<%= listing._id %>/edit"
                                                    class="btn btn-sm btn-warning flex-fill">
                                                    <i class="fas fa-edit me-1"></i>Edit
                                                </a>
                                                <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST"
                                                    class="flex-fill">
                                                    <button class="btn btn-sm btn-danger w-100"
                                                        onclick="return confirm('Are you sure?')">
                                                        <i class="fas fa-trash me-1"></i>Delete
                                                    </button>
                                                </form>
                                            </div>

                                            <!-- Stats -->
                                            <div class="mt-3 pt-3 border-top">
                                                <small class="text-muted">
                                                    <i class="fas fa-calendar me-1"></i>
                                                    Created <%= new Date(listing.createdAt).toLocaleDateString() %>
                                                </small>
                                                <% if (listing.reviews && listing.reviews.length> 0) { %>
                                                    <br>
                                                    <small class="text-muted">
                                                        <i class="fas fa-star text-warning me-1"></i>
                                                        <%= listing.reviews.length %>
                                                            <%= listing.reviews.length===1 ? 'Review' : 'Reviews' %>
                                                    </small>
                                                    <% } %>
                                            </div>
                                        </div>

                        </div>
                    </div>
                    <% }) %>
            </div>
            <% } else { %>
                <div class="text-center py-5">
                    <i class="fas fa-building fa-4x text-muted mb-3"></i>
                    <h3 class="text-muted">No Listings Yet</h3>
                    <p class="text-muted">You haven't created any listings. Start by adding your first property!</p>
                    <a href="/listings/new" class="btn btn-primary mt-3">
                        <i class="fas fa-plus-circle me-2"></i>Create First Listing
                    </a>
                </div>
                <% } %>
    </div>

    <style>
        .category-badge {
            position: absolute;
            top: 10px;
            right: 10px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
            z-index: 10;
        }
    </style>