<% layout('layouts/boilerplate') %>

  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

  <div class="container mt-4">
    <div class="row">
      <!-- Main Content -->
      <div class="col-lg-8">
        <div class="card shadow-sm mb-4">
          <!-- Image Gallery -->
          <% if (listing.images && listing.images.length> 0) { %>
            <div id="listingCarousel" class="carousel slide" data-bs-ride="carousel">
              <div class="carousel-inner">
                <% listing.images.forEach((img, index)=> { %>
                  <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
                    <img src="<%= img.url %>" class="d-block w-100 listing-image" alt="<%= listing.title %>">
                  </div>
                  <% }) %>
              </div>
              <% if (listing.images.length> 1) { %>
                <button class="carousel-control-prev" type="button" data-bs-target="#listingCarousel"
                  data-bs-slide="prev">
                  <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                  <span class="visually-hidden">Previous</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#listingCarousel"
                  data-bs-slide="next">
                  <span class="carousel-control-next-icon" aria-hidden="true"></span>
                  <span class="visually-hidden">Next</span>
                </button>
                <% } %>
            </div>
            <% } else { %>
              <img src="https://via.placeholder.com/800x400?text=No+Image" class="card-img-top listing-image"
                alt="No image">
              <% } %>

                <div class="card-body">
                  <h2 class="card-title mb-3">
                    <%= listing.title %>
                  </h2>

                  <div class="mb-3">
                    <h4 class="text-primary">₹<%= listing.price.toLocaleString() %> <small class="text-muted">/
                          night</small></h4>
                  </div>

                  <div class="mb-3">
                    <p class="mb-1"><i class="fas fa-map-marker-alt text-danger me-2"></i><strong>Location:</strong>
                      <%= listing.location %>, <%= listing.country %>
                    </p>
                    <% if (listing.author) { %>
                      <p class="mb-1"><i class="fas fa-user text-info me-2"></i><strong>Hosted by:</strong>
                        <%= listing.author.username %>
                      </p>
                      <% } %>
                  </div>

                  <div class="mb-3">
                    <h5>Description</h5>
                    <p class="text-muted">
                      <%= listing.description %>
                    </p>
                  </div>

                  <% if (currUser && listing.author && currUser._id.toString()===listing.author._id.toString()) { %>
                    <div class="d-flex gap-2">
                      <a href="/listings/<%= listing._id %>/edit" class="btn btn-warning">
                        <i class="fas fa-edit me-1"></i> Edit Listing
                      </a>
                      <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST" class="d-inline">
                        <button class="btn btn-danger"
                          onclick="return confirm('Are you sure you want to delete this listing?')">
                          <i class="fas fa-trash me-1"></i> Delete
                        </button>
                      </form>
                    </div>
                    <% } %>
                </div>
        </div>

        <!-- Map Section -->
        <div class="card shadow-sm mb-4">
          <div class="card-body">
            <h5 class="card-title mb-3"><i class="fas fa-map me-2"></i>Location</h5>
            <div id="map" style="height: 400px; width: 100%; border-radius: 8px;"></div>
          </div>
        </div>

        <!-- Reviews Section -->
        <div class="card shadow-sm mb-4">
          <div class="card-body">
            <h5 class="card-title mb-3"><i class="fas fa-comments me-2"></i>Reviews</h5>

            <% if (currUser) { %>
              <%- include("../includes/reviewForm") %>
                <% } else { %>
                  <p class="text-muted">Please <a href="/login">log in</a> to leave a review.</p>
                  <% } %>

                    <% if (listing.reviews && listing.reviews.length> 0) { %>
                      <hr class="my-4">
                      <% listing.reviews.forEach(review=> { %>
                        <div class="review-card mb-3 p-3 border rounded">
                          <div class="d-flex justify-content-between align-items-start">
                            <div>
                              <h6 class="mb-1">
                                <%= review.author ? review.author.username : 'Anonymous' %>
                              </h6>
                              <div class="starability-result mb-2" data-rating="<%= review.rating %>">
                                Rated: <%= review.rating %> stars
                              </div>
                              <p class="mb-0 text-muted">
                                <%= review.body %>
                              </p>
                            </div>
                            <% if (currUser && review.author && currUser._id.toString()===review.author._id.toString())
                              { %>
                              <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                                method="POST">
                                <button class="btn btn-sm btn-outline-danger">
                                  <i class="fas fa-trash"></i>
                                </button>
                              </form>
                              <% } %>
                          </div>
                        </div>
                        <% }) %>
                          <% } else { %>
                            <p class="text-muted">No reviews yet. Be the first to review!</p>
                            <% } %>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="col-lg-4">
        <div class="card shadow-sm sticky-top" style="top: 20px;">
          <div class="card-body">
            <h5 class="card-title">Quick Info</h5>
            <ul class="list-unstyled">
              <li class="mb-2"><i class="fas fa-dollar-sign text-success me-2"></i> ₹<%= listing.price.toLocaleString()
                  %> per night</li>
              <li class="mb-2"><i class="fas fa-map-marker-alt text-danger me-2"></i>
                <%= listing.location %>
              </li>
              <li class="mb-2"><i class="fas fa-flag text-primary me-2"></i>
                <%= listing.country %>
              </li>
              <% if (listing.reviews && listing.reviews.length> 0) {
                let totalRating = 0;
                listing.reviews.forEach(r => totalRating += r.rating);
                let avgRating = (totalRating / listing.reviews.length).toFixed(1);
                %>
                <li class="mb-2">
                  <i class="fas fa-star text-warning me-2"></i>
                  <strong>
                    <%= avgRating %>
                  </strong> (<%= listing.reviews.length %>
                    <%= listing.reviews.length===1 ? 'Review' : 'Reviews' %>)
                </li>
                <% } %>
            </ul>
            <a href="/listings" class="btn btn-outline-primary w-100 mt-3">
              <i class="fas fa-arrow-left me-1"></i> Back to Listings
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

  <script>
  // Initialize Leaflet map
  <% if (listing.geometry && listing.geometry.coordinates && listing.geometry.coordinates.length === 2) { %>
    const coordinates = <%= JSON.stringify(listing.geometry.coordinates) %>;
      // Leaflet uses [lat, lng], GeoJSON uses [lng, lat]
      const latLng = [coordinates[1], coordinates[0]];

      // Create map
      const map = L.map('map').setView(latLng, 13);

      // Add OpenStreetMap tiles
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19,
        attribution: '© OpenStreetMap contributors'
      }).addTo(map);

      // Add marker with popup
      L.marker(latLng).addTo(map)
        .bindPopup("<b><%= listing.title %></b><br><%= listing.location %>")
        .openPopup();
  <% } else { %>
      // No coordinates available
      document.getElementById('map').innerHTML = '<div class="alert alert-info m-0">Map location not available</div>';
  <% } %>
  </script>

  <style>
    .listing-image {
      height: 400px;
      object-fit: cover;
    }

    .review-card {
      background-color: #f8f9fa;
      transition: transform 0.2s;
    }

    .review-card:hover {
      transform: translateX(5px);
    }
  </style>