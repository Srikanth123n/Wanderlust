<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= typeof title !== 'undefined' ? title : 'Wanderlust' %></title>

  <!-- Bootstrap CSS (no integrity attr to avoid SRI mismatch) -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Font Awesome (no integrity attr) -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

  <!-- Local CSS -->
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/starbility.css">
</head>
<body>
  <%- include('includes/navbar') %>
  <%- include('includes/flash') %>
  <div class="container my-4">
    <%- body %>
  </div>
  <%- include('includes/footer') %>

  <!-- Bootstrap JS (no integrity attr) -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

  <!-- Local JS -->
  <script src="/js/script.js"></script>
</body>
</html>
