<% layout('layouts/boilerplate') %>

  <div class="container mt-5">
    <div class="row">
      <div class="col-md-8 offset-md-2">
        <div class="card shadow-lg text-center">
          <div class="card-body p-5">
            <div class="mb-4">
              <i class="fas fa-exclamation-triangle fa-5x text-warning"></i>
            </div>
            <h1 class="display-1 fw-bold text-primary">
              <%= err.statusCode || 500 %>
            </h1>
            <h2 class="card-title mb-3">
              <%= err.message || "Something went wrong!" %>
            </h2>
            <p class="card-text text-muted mb-4">
              We're sorry, but something unexpected happened. Please try again later or return to the home page.
            </p>

            <% if (process.env.NODE_ENV !=='production' && err.stack) { %>
              <div class="alert alert-danger text-start mt-4">
                <h5>Stack Trace (Development Only):</h5>
                <pre class="mb-0"><%= err.stack %></pre>
              </div>
              <% } %>

                <div class="mt-4">
                  <a href="/listings" class="btn btn-primary btn-lg me-2">
                    <i class="fas fa-home me-2"></i>Go Home
                  </a>
                  <a href="javascript:history.back()" class="btn btn-outline-secondary btn-lg">
                    <i class="fas fa-arrow-left me-2"></i>Go Back
                  </a>
                </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <style>
    .card {
      border: none;
      border-radius: 15px;
    }

    pre {
      background: #f8f9fa;
      padding: 1rem;
      border-radius: 8px;
      font-size: 0.875rem;
      max-height: 300px;
      overflow-y: auto;
    }
  </style>